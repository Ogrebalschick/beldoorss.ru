# Ignore configuration files with database credentials
/config.php
/admin/config.php

# Ignore system storage directories
/system/storage/backup/*
!/system/storage/backup/index.html
/system/storage/cache/*
!/system/storage/cache/index.html
/system/storage/download/*
!/system/storage/download/index.html
/system/storage/logs/*
!/system/storage/logs/index.html
/system/storage/marketplace/*
!/system/storage/marketplace/index.html
/system/storage/session/*
!/system/storage/session/index.html
/system/storage/upload/*
!/system/storage/upload/index.html
/system/storage/modification/*
!/system/storage/modification/index.html

# Ignore image cache
/image/cache/*

# Ignore vqmod (if using)
/vqmod/*
!/vqmod/index.html

# Ignore installation directory after setup
/install

# Ignore development and OS-specific files
.idea
.vscode
.DS_Store
Thumbs.db

# Ignore other temporary and vendor files
*.log
*.sql
*.zip
*.tar.gz
vendor/

docs/
image/